---
import { getSections } from "../data/sections-registry";
import { useTranslation, getLocalePath, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
  currentSlug: string;
  agentName: string;
}

const { lang, currentSlug, agentName } = Astro.props;
const t = useTranslation(lang);

function sectionUrl(slug: string): string {
  return getLocalePath(lang, `/${agentName}/${slug}`);
}
---

<aside class="hidden w-64 shrink-0 lg:block">
  <nav class="sticky top-20 space-y-1 pr-4" aria-label="Docs navigation">
    <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
      {agentName.toUpperCase()}
    </p>
    {
      getSections(agentName).map((section) => {
        const isActive = section.slug === currentSlug || (section.slug === "hooks" && currentSlug === "hooks-cheatsheet");
        const isCheatsheetActive = currentSlug === "hooks-cheatsheet";
        return (
          <div>
            <a
              href={sectionUrl(section.slug)}
              class:list={[
                "flex items-center gap-2 rounded-lg px-3 py-2 text-sm transition-colors",
                isActive
                  ? "bg-[var(--color-accent-indigo)]/10 font-medium text-[var(--color-accent-cyan)]"
                  : "text-[var(--color-text-secondary)] hover:bg-white/5 hover:text-[var(--color-text-primary)]",
              ]}
              aria-current={isActive && !isCheatsheetActive ? "page" : undefined}
            >
              <span
                class:list={[
                  "flex h-5 w-5 items-center justify-center rounded font-mono text-[10px]",
                  isActive
                    ? "bg-[var(--color-accent-indigo)]/20 text-[var(--color-accent-indigo)]"
                    : "bg-white/5 text-[var(--color-text-muted)]",
                ]}
              >
                {section.number}
              </span>
              {t(section.navKey as any)}
            </a>
            {section.slug === "hooks" && agentName === "claude" && (
              <a
                href={sectionUrl("hooks-cheatsheet")}
                class:list={[
                  "ml-7 flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs transition-colors",
                  isCheatsheetActive
                    ? "font-medium text-[var(--color-accent-cyan)]"
                    : "text-[var(--color-text-muted)] hover:bg-white/5 hover:text-[var(--color-text-primary)]",
                ]}
                aria-current={isCheatsheetActive ? "page" : undefined}
              >
                {t("nav.claude.hooksCheatsheet" as any)}
              </a>
            )}
          </div>
        );
      })
    }
  </nav>
</aside>

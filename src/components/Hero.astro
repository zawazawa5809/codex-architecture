---
import { useTranslation, getLocalePath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "ja" } = Astro.props;
const t = useTranslation(lang);
const ctaHref = getLocalePath(lang, "/codex/overview");
---

<section class="relative overflow-hidden pb-20 pt-32">
  <!-- Glow effects -->
  <div
    class="glow-animate pointer-events-none absolute left-1/4 top-0 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-[var(--color-accent-indigo)] opacity-[0.08] blur-[140px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="glow-animate pointer-events-none absolute right-1/4 top-20 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-[var(--color-accent-cyan)] opacity-[0.06] blur-[140px]"
    style="animation-delay: -4s;"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-4 text-center">
    <div
      class="hero-enter mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-white/5 px-4 py-1.5"
    >
      <span class="h-2 w-2 rounded-full bg-[var(--color-accent-emerald)] animate-pulse"></span>
      <span class="text-xs text-[var(--color-text-secondary)]">OpenAI Codex CLI — Apache-2.0</span>
    </div>

    <h1 class="hero-enter-delay-1 mb-4 text-5xl font-bold tracking-tight md:text-6xl">
      <span class="text-[var(--color-text-primary)]">{t("hero.title")}</span>
    </h1>

    <p class="hero-enter-delay-1 mb-8 text-xl text-[var(--color-accent-cyan)] md:text-2xl">
      {t("hero.subtitle")}
    </p>

    <p class="hero-enter-delay-2 mb-10 font-mono text-sm text-[var(--color-text-muted)]">
      {t("hero.stats")}
    </p>

    <div class="hero-enter-delay-3 flex justify-center gap-4">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent-indigo)] px-6 py-3 text-sm font-medium text-white transition-all hover:bg-[var(--color-accent-indigo)]/80 hover:shadow-lg hover:shadow-[var(--color-accent-indigo)]/20"
      >
        {t("hero.cta")}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"
          ></path>
        </svg>
      </a>
      <a
        href="https://github.com/openai/codex"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] px-6 py-3 text-sm font-medium text-[var(--color-text-secondary)] transition-all hover:border-[var(--color-accent-indigo)] hover:text-[var(--color-text-primary)]"
      >
        GitHub
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>

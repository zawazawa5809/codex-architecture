---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import DocsPagination from "../components/DocsPagination.astro";
import { type Lang } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  currentSlug: string;
  agentName: string;
}

const { title, description = "", lang = "ja", currentSlug, agentName } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang} currentSlug={currentSlug} activeAgent={agentName}>
  <div class="mx-auto max-w-7xl px-3 py-16 sm:px-4 lg:py-24">
    <div class="flex gap-8">
      <DocsSidebar
        lang={lang}
        currentSlug={currentSlug}
        agentName={agentName}
      />
      <article class="min-w-0 flex-1">
        <slot />
        <DocsPagination
          lang={lang}
          currentSlug={currentSlug}
          agentName={agentName}
        />
      </article>
    </div>
  </div>
</BaseLayout>

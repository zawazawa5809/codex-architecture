---
import { getEntry, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { useTranslation, type Lang } from "../../i18n/utils";
import { claudeSections, type SectionMeta } from "../../data/claude-sections";

import ClaudeOverview from "../../diagrams/ClaudeOverview.tsx";
import ClaudeMdFlow from "../../diagrams/ClaudeMdFlow.tsx";
import SkillsFlow from "../../diagrams/SkillsFlow.tsx";
import HooksFlow from "../../diagrams/HooksFlow.tsx";
import McpIntegration from "../../diagrams/McpIntegration.tsx";
import PermissionsFlow from "../../diagrams/PermissionsFlow.tsx";

const lang = "ja" as Lang;

export function getStaticPaths() {
  return claudeSections.map((section) => ({
    params: { slug: section.slug },
    props: { section },
  }));
}

interface Props {
  section: SectionMeta;
}

const { section } = Astro.props;
const t = useTranslation(lang);

const entry = await getEntry("claude_ja", section.entryId);
if (!entry) throw new Error(`Content not found: claude_ja/${section.entryId}`);
const { Content } = await render(entry);

const accentVar = `var(--color-accent-${section.accent})`;
const diagramBorderClass = section.accent === "rose"
  ? "border-[var(--color-accent-rose)]/20"
  : "border-[var(--color-border)]";
---

<DocsLayout
  title={`${entry.data.title} — Claude Code`}
  description={entry.data.description}
  lang={lang}
  currentSlug={section.slug}
  agentName="claude"
>
  <div class="mb-8 flex items-center gap-3">
    <span
      class="flex h-8 w-8 items-center justify-center rounded-lg font-mono text-sm"
      style={`background: color-mix(in srgb, ${accentVar} 20%, transparent); color: ${accentVar}`}
    >
      {section.number}
    </span>
    <h1 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">
      {entry.data.title}
    </h1>
    {section.badge && (
      <span
        class="rounded-full px-3 py-1 text-xs"
        style={`background: color-mix(in srgb, ${accentVar} 10%, transparent); color: ${accentVar}`}
      >
        {section.badge[lang]}
      </span>
    )}
  </div>

  {section.diagram && (
    <div class={`mb-10 overflow-x-auto rounded-xl border ${diagramBorderClass} bg-white/[0.02] p-6`} style="touch-action: pinch-zoom">
      <div>
        {section.diagram === "ClaudeOverview" && <ClaudeOverview client:visible />}
        {section.diagram === "ClaudeMdFlow" && <ClaudeMdFlow client:visible />}
        {section.diagram === "SkillsFlow" && <SkillsFlow client:visible />}
        {section.diagram === "HooksFlow" && <HooksFlow client:visible />}
        {section.diagram === "McpIntegration" && <McpIntegration client:visible />}
        {section.diagram === "PermissionsFlow" && <PermissionsFlow client:visible />}
      </div>
    </div>
  )}

  <div class="prose-dark prose prose-lg max-w-none">
    <Content />
  </div>
</DocsLayout>

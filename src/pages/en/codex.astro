---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import { useTranslation, getLocalePath, type Lang } from "../../i18n/utils";
import { codexSections } from "../../data/codex-sections";

const lang = "en" as Lang;
const t = useTranslation(lang);

const whyCards = [
  {
    icon: "🛡️",
    title: t("card.security"),
    desc: t("card.securityDesc"),
    color: "var(--color-accent-rose)",
  },
  {
    icon: "🏗️",
    title: t("card.design"),
    desc: t("card.designDesc"),
    color: "var(--color-accent-indigo)",
  },
  {
    icon: "🚀",
    title: t("card.builder"),
    desc: t("card.builderDesc"),
    color: "var(--color-accent-emerald)",
  },
];

function sectionUrl(slug: string): string {
  return getLocalePath(lang, `/codex/${slug}`);
}
---

<BaseLayout title={`Codex CLI — ${t("site.title")}`} description={t("site.description")} lang={lang}>
  <Hero lang={lang} />

  {/* Why Study Section */}
  <section id="why-study" class="py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-12 text-center text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">
        {t("section.whyStudy")}
      </h2>
      <div class="reveal grid gap-6 md:grid-cols-3">
        {
          whyCards.map((card) => (
            <div class="card-hover rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6 hover:border-[var(--color-accent-indigo)]/50 hover:bg-white/[0.04]">
              <div
                class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg text-2xl"
                style={`background: color-mix(in srgb, ${card.color} 15%, transparent)`}
              >
                {card.icon}
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--color-text-primary)]">
                {card.title}
              </h3>
              <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">{card.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Sections Index */}
  <section class="border-t border-[var(--color-border)] py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="mb-8 text-center text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">
        Sections
      </h2>
      <div class="reveal space-y-3">
        {
          codexSections.map((section) => {
            const accentVar = `var(--color-accent-${section.accent})`;
            return (
              <a
                href={sectionUrl(section.slug)}
                class="card-hover flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-5 hover:border-[var(--color-accent-indigo)]/50 hover:bg-white/[0.04]"
              >
                <span
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg font-mono text-sm"
                  style={`background: color-mix(in srgb, ${accentVar} 20%, transparent); color: ${accentVar}`}
                >
                  {section.number}
                </span>
                <span class="text-[var(--color-text-primary)]">
                  {t(section.navKey as any)}
                </span>
                {section.badge && (
                  <span
                    class="rounded-full px-2 py-0.5 text-[10px]"
                    style={`background: color-mix(in srgb, ${accentVar} 10%, transparent); color: ${accentVar}`}
                  >
                    {section.badge[lang]}
                  </span>
                )}
                <span class="ml-auto text-[var(--color-text-muted)]">&rarr;</span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  {/* References & License */}
  <section id="references" class="border-t border-[var(--color-border)] py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="mb-8 text-2xl font-bold text-[var(--color-text-primary)]">References & License</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
          <h3 class="mb-3 text-sm font-semibold text-[var(--color-accent-cyan)]">Links</h3>
          <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
            <li>
              <a href="https://github.com/openai/codex" class="text-[var(--color-accent-cyan)] hover:underline" target="_blank" rel="noopener noreferrer">
                OpenAI Codex CLI (GitHub)
              </a>
            </li>
            <li>
              <a href="https://www.apache.org/licenses/LICENSE-2.0" class="text-[var(--color-accent-cyan)] hover:underline" target="_blank" rel="noopener noreferrer">
                Apache License 2.0
              </a>
            </li>
            <li>
              <a href="https://modelcontextprotocol.io/" class="text-[var(--color-accent-cyan)] hover:underline" target="_blank" rel="noopener noreferrer">
                Model Context Protocol (MCP)
              </a>
            </li>
          </ul>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
          <h3 class="mb-3 text-sm font-semibold text-[var(--color-accent-cyan)]">License Notice</h3>
          <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">
            Code snippets referenced on this site are from the OpenAI Codex CLI repository, used under the Apache License 2.0.
            "OpenAI" and "Codex" are trademarks of their respective owners. This site is an independent educational resource.
          </p>
          <a href={getLocalePath(lang, "/")} class="mt-3 inline-block text-xs text-[var(--color-accent-cyan)] hover:underline">
            View NOTICE file →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

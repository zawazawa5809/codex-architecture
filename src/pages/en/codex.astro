---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import { useTranslation, getLocalePath, getBasePath, type Lang } from "../../i18n/utils";

// Diagram components (React Islands) — no translated text, usable as-is
import ArchitectureOverview from "../../diagrams/ArchitectureOverview.tsx";
import AgentLoop from "../../diagrams/AgentLoop.tsx";
import ToolSystem from "../../diagrams/ToolSystem.tsx";
import SandboxFlow from "../../diagrams/SandboxFlow.tsx";
import ApprovalFlow from "../../diagrams/ApprovalFlow.tsx";
import SqEqAnimation from "../../diagrams/SqEqAnimation.tsx";

// MDX Content (English)
import Overview from "../../content/en/codex/01-overview.mdx";
import AgentLoopContent from "../../content/en/codex/02-agent-loop.mdx";
import ToolSystemContent from "../../content/en/codex/03-tool-system.mdx";
import SandboxContent from "../../content/en/codex/04-sandbox.mdx";
import ApprovalContent from "../../content/en/codex/05-approval.mdx";
import ConfigContent from "../../content/en/codex/06-config.mdx";
import ComparisonContent from "../../content/en/codex/07-comparison.mdx";
import TakeawaysContent from "../../content/en/codex/08-takeaways.mdx";

const lang = "en" as Lang;
const t = useTranslation(lang);
const basePath = getBasePath();

const whyCards = [
  {
    icon: "🛡️",
    title: t("card.security"),
    desc: t("card.securityDesc"),
    color: "var(--color-accent-rose)",
  },
  {
    icon: "🏗️",
    title: t("card.design"),
    desc: t("card.designDesc"),
    color: "var(--color-accent-indigo)",
  },
  {
    icon: "🚀",
    title: t("card.builder"),
    desc: t("card.builderDesc"),
    color: "var(--color-accent-emerald)",
  },
];
---

<BaseLayout title={`Codex CLI — ${t("site.title")}`} description={t("site.description")} lang={lang}>
  <Hero lang={lang} />

  {/* Why Study Section */}
  <section id="why-study" class="py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-12 text-center text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">
        {t("section.whyStudy")}
      </h2>
      <div class="reveal grid gap-6 md:grid-cols-3">
        {
          whyCards.map((card) => (
            <div class="card-hover rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6 hover:border-[var(--color-accent-indigo)]/50 hover:bg-white/[0.04]">
              <div
                class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg text-2xl"
                style={`background: color-mix(in srgb, ${card.color} 15%, transparent)`}
              >
                {card.icon}
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--color-text-primary)]">
                {card.title}
              </h3>
              <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">{card.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Section 1: Architecture Overview */}
  <section id="overview" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-indigo)]/20 font-mono text-sm text-[var(--color-accent-indigo)]">1</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Architecture Overview</h2>
      </div>

      <div class="mb-10 overflow-x-auto rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
        <div class="min-w-[600px]">
          <ArchitectureOverview client:visible />
        </div>
      </div>

      <div class="mb-8 overflow-x-auto rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
        <h3 class="mb-4 text-lg font-semibold text-[var(--color-accent-cyan)]">SQ/EQ Message Flow</h3>
        <div class="min-w-[600px]">
          <SqEqAnimation client:visible />
        </div>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <Overview />
      </div>
    </div>
  </section>

  {/* Section 2: Agent Loop */}
  <section id="agent-loop" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-indigo)]/20 font-mono text-sm text-[var(--color-accent-indigo)]">2</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Agent Loop</h2>
      </div>

      <div class="mb-10 overflow-x-auto rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
        <div class="min-w-[600px]">
          <AgentLoop client:visible />
        </div>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <AgentLoopContent />
      </div>
    </div>
  </section>

  {/* Section 3: Tool System */}
  <section id="tool-system" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-indigo)]/20 font-mono text-sm text-[var(--color-accent-indigo)]">3</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Tool System</h2>
      </div>

      <div class="mb-10 overflow-x-auto rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
        <div class="min-w-[600px]">
          <ToolSystem client:visible />
        </div>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <ToolSystemContent />
      </div>
    </div>
  </section>

  {/* Section 4: Sandbox Security */}
  <section id="sandbox" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-rose)]/20 font-mono text-sm text-[var(--color-accent-rose)]">4</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Sandbox Security</h2>
        <span class="rounded-full bg-[var(--color-accent-rose)]/10 px-3 py-1 text-xs text-[var(--color-accent-rose)]">Core Content</span>
      </div>

      <div class="mb-10 overflow-x-auto rounded-xl border border-[var(--color-accent-rose)]/20 bg-white/[0.02] p-6">
        <div class="min-w-[600px]">
          <SandboxFlow client:visible />
        </div>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <SandboxContent />
      </div>
    </div>
  </section>

  {/* Section 5: Approval System */}
  <section id="approval" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-indigo)]/20 font-mono text-sm text-[var(--color-accent-indigo)]">5</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Approval System</h2>
      </div>

      <div class="mb-10 overflow-x-auto rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
        <div class="min-w-[600px]">
          <ApprovalFlow client:visible />
        </div>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <ApprovalContent />
      </div>
    </div>
  </section>

  {/* Section 6: Configuration */}
  <section id="config" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-indigo)]/20 font-mono text-sm text-[var(--color-accent-indigo)]">6</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Configuration System</h2>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <ConfigContent />
      </div>
    </div>
  </section>

  {/* Section 7: Comparison */}
  <section id="comparison" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-indigo)]/20 font-mono text-sm text-[var(--color-accent-indigo)]">7</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Tool Comparison</h2>
      </div>

      <div class="mb-10">
        <ComparisonTable lang={lang} />
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <ComparisonContent />
      </div>
    </div>
  </section>

  {/* Section 8: Takeaways */}
  <section id="takeaways" class="border-t border-[var(--color-border)] py-20">
    <div class="reveal mx-auto max-w-6xl px-4">
      <div class="mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-emerald)]/20 font-mono text-sm text-[var(--color-accent-emerald)]">8</span>
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">Design Pattern Takeaways</h2>
      </div>

      <div class="prose-dark prose prose-lg max-w-none">
        <TakeawaysContent />
      </div>
    </div>
  </section>

  {/* References & License */}
  <section id="references" class="border-t border-[var(--color-border)] py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="mb-8 text-2xl font-bold text-[var(--color-text-primary)]">References & License</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
          <h3 class="mb-3 text-sm font-semibold text-[var(--color-accent-cyan)]">Links</h3>
          <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
            <li>
              <a href="https://github.com/openai/codex" class="text-[var(--color-accent-cyan)] hover:underline" target="_blank" rel="noopener noreferrer">
                OpenAI Codex CLI (GitHub)
              </a>
            </li>
            <li>
              <a href="https://www.apache.org/licenses/LICENSE-2.0" class="text-[var(--color-accent-cyan)] hover:underline" target="_blank" rel="noopener noreferrer">
                Apache License 2.0
              </a>
            </li>
            <li>
              <a href="https://modelcontextprotocol.io/" class="text-[var(--color-accent-cyan)] hover:underline" target="_blank" rel="noopener noreferrer">
                Model Context Protocol (MCP)
              </a>
            </li>
          </ul>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-white/[0.02] p-6">
          <h3 class="mb-3 text-sm font-semibold text-[var(--color-accent-cyan)]">{t("footer.licenseTitle")}</h3>
          <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">
            {t("footer.licenseBody")}
          </p>
          <a href={`${basePath}/NOTICE`} class="mt-3 inline-block text-xs text-[var(--color-accent-cyan)] hover:underline">
            View NOTICE file →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
